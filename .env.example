# Copy to .env to run the API/worker on the host against compose infra.
# (Inside compose these are set in docker-compose.yml.)

LOG_LEVEL=INFO

POSTGRES_DSN=postgresql+asyncpg://orderflow:orderflow@localhost:5433/orderflow
REDIS_URL=redis://localhost:6380/0
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Cache-aside TTL for GET /orders/{id}
CACHE_TTL_SECONDS=60

# Must exceed the worst-case processing time of a single message.
IDEMPOTENCY_LOCK_TTL_SECONDS=60
IDEMPOTENCY_DONE_TTL_SECONDS=86400

# 1 initial delivery + 3 retries, then the DLQ.
MAX_ATTEMPTS=4
RETRY_BASE_DELAY_SECONDS=2
RETRY_MAX_DELAY_SECONDS=60

# Simulated work per order.
PROCESSING_DELAY_SECONDS=0.3
